layout {
  cwd "."

  default_tab_template {
    pane size=1 borderless=true {
      plugin location="tab-bar"
    }
    children
    pane size=2 borderless=true {
      plugin location="status-bar"
    }
  }

  tab name="s3browser" split_direction="vertical" {
    pane name="caddy" command="./scripts/caddy.sh"

    pane name="s3browser" command="bash" focus=true {
      // Adjust this command/flags to whatever starts your s3browser on :8170.
      args "-lc" "s3browser"
    }
  }
}
