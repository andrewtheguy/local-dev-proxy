layout {
  cwd "."

  default_tab_template {
    pane size=1 borderless=true {
      plugin location="tab-bar"
    }
    children
    pane size=2 borderless=true {
      plugin location="status-bar"
    }
  }

  tab name="s3browser" split_direction="vertical" {
    pane name="caddy" command="./scripts/caddy.py"
    pane name="minio" command="./scripts/minio.py"
    pane name="s3browser" command="./scripts/s3browser.py" focus=true
  }
}
