layout {
  cwd "."

  default_tab_template {
    pane size=1 borderless=true {
      plugin location="tab-bar"
    }
    children
    pane size=2 borderless=true {
      plugin location="status-bar"
    }
  }

  tab name="s3browser" split_direction="vertical" {
    pane name="minio" command="uv run local-dev-proxy service minio"
    pane name="s3browser" command="uv run local-dev-proxy service s3browser" focus=true
  }
}
