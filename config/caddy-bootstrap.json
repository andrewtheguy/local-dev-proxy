{
  "admin": {
    "listen": "127.0.0.1:2020"
  },
  "apps": {
    "http": {
      "http_port": 2800,
      "servers": {
        "srv0": {
          "listen": [
            "127.0.0.1:2800",
            "[::1]:2800"
          ],
          "automatic_https": {
            "disable": true
          },
          "routes": [
            {
              "@id": "route-fallback",
              "handle": [
                {
                  "handler": "static_response",
                  "status_code": 404,
                  "body": "Not Found caddy"
                }
              ],
              "terminal": true
            }
          ]
        }
      }
    }
  }
}
