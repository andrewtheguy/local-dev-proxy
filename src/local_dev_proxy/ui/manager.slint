import { TabWidget, Button, ListView, TextEdit, ComboBox, SpinBox, CheckBox, GroupBox, ScrollView } from "std-widgets.slint";

// One row of the Services table.
export struct ServiceRow {
    name: string,
    status: string,
    pid: string,
    restarts: string,
    exit: string,
}

// One row of the (flat, grouped) Routes list. `kind` is service-header | route | note.
export struct RouteRow {
    kind: string,
    text: string,
    url: string,
    target: string,
    muted: bool,
}

// Shared, clearly-visible table chrome (Tk-Treeview-like borders/grid), so panels
// don't blend into the window background the way the default Fluent styling does.
global Ui {
    out property <color> border: #8a9099;      // outer frame + header divider
    out property <color> grid: #dcdfe3;         // row separators
    out property <color> header-bg: #e6e8eb;    // column-header strip
    out property <color> selection: #cfe0f5;    // selected row
    out property <color> hover: #eef4fb;         // hovered clickable row
    out property <color> zebra: #f6f7f9;         // alternating row
    out property <color> group-bg: #eef0f2;      // routes service-header row
}

export component MainWindow inherits Window {
    title: "Local Dev Proxy — Manager v" + root.version;
    background: #fbfbfc;
    icon: root.app_icon;
    preferred-width: 760px;
    preferred-height: 560px;
    min-width: 560px;
    min-height: 400px;
    default-font-size: 13px;

    // --- inputs from the Python controller ---
    in property <string> version;
    in property <image> app_icon;
    in property <bool> editing;                 // true while config is being edited
    in property <string> view: "services";      // services | readonly | edit
    in property <string> banner;                // Services-tab error/mode message
    in property <string> status_text;
    in property <int> status_level;             // 0 neutral, 1 success, 2 error

    in property <[ServiceRow]> service_rows;
    in-out property <int> selected_row: -1;
    in property <bool> can_start;
    in property <bool> can_stop;
    in property <bool> can_restart;
    in property <string> sel_caption: "Selected service — click a row to control it";

    in-out property <string> config_text;
    in property <bool> dirty;

    in property <[string]> log_services;
    in-out property <int> log_current: -1;
    in-out property <int> log_lines: 200;
    in-out property <bool> log_follow;
    in property <string> log_text;

    in property <[RouteRow]> route_rows;
    in property <string> routes_banner;

    in-out property <int> current_tab;

    // --- callbacks into the Python controller ---
    callback quit();
    callback show_readonly();
    callback show_services();
    callback stop_to_edit();
    callback start_all();
    callback validate();
    callback save();
    callback reload_file();
    callback start_service();
    callback stop_service();
    callback restart_service();
    callback row_selected(int);
    callback config_edited();
    callback select_log(int);
    callback follow_toggled(bool);
    callback refresh_logs();
    callback reload_routes();
    callback open_url(string);

    function status_color() -> brush {
        root.status_level == 1 ? #007000 : root.status_level == 2 ? #b00000 : #303030
    }

    // Pin the log view to its newest line (like `tail -f` / the old see("end")).
    // Called from Python after the log text is refreshed (deferred a frame so the
    // viewport height reflects the new content).
    public function scroll_log_bottom() {
        log_scroll.viewport-y = min(0px, log_scroll.visible-height - log_scroll.viewport-height);
    }

    VerticalLayout {
        padding: 8px;
        spacing: 6px;

        // Toolbar: version (left), Quit (right).
        HorizontalLayout {
            Text { text: "v" + root.version; color: #888888; vertical-alignment: center; }
            Rectangle { horizontal-stretch: 1; }
            Button { text: "Quit"; clicked => { root.quit(); } }
        }

        TabWidget {
            current-index <=> root.current_tab;
            Tab {
                title: "Services";
                VerticalLayout {
                    padding: 8px;
                    spacing: 4px;

                    if root.banner != "": Text {
                        text: root.banner;
                        color: #b00000;
                        wrap: word-wrap;
                    }

                    HorizontalLayout {
                        if root.view == "services": Button {
                            text: "View Config";
                            clicked => { root.show_readonly(); }
                        }
                        if root.view == "readonly": Button {
                            text: "Back to Services";
                            clicked => { root.show_services(); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Text {
                            text: root.status_text;
                            color: root.status-color();
                            vertical-alignment: center;
                        }
                    }

                    // --- services list view ---
                    if root.view == "services": VerticalLayout {
                        spacing: 6px;
                        Rectangle {
                            vertical-stretch: 1;
                            border-width: 1px;
                            border-color: Ui.border;
                            border-radius: 4px;
                            background: #ffffff;
                            clip: true;
                            VerticalLayout {
                                Rectangle {
                                    height: 26px;
                                    background: Ui.header-bg;
                                    HorizontalLayout {
                                        padding-left: 8px;
                                        padding-right: 8px;
                                        spacing: 8px;
                                        Text { text: "service"; width: 150px; font-weight: 700; vertical-alignment: center; }
                                        Text { text: "status"; width: 100px; font-weight: 700; vertical-alignment: center; }
                                        Text { text: "pid"; width: 80px; font-weight: 700; vertical-alignment: center; }
                                        Text { text: "restarts"; width: 80px; font-weight: 700; vertical-alignment: center; }
                                        Text { text: "exit code"; horizontal-stretch: 1; font-weight: 700; vertical-alignment: center; }
                                    }
                                }
                                Rectangle { height: 1px; background: Ui.border; }
                                ListView {
                                    vertical-stretch: 1;
                                    for row[idx] in root.service_rows: Rectangle {
                                        height: 29px;
                                        background: idx == root.selected_row ? Ui.selection
                                            : svc_ta.has-hover ? Ui.hover
                                            : Math.mod(idx, 2) == 0 ? #ffffff : Ui.zebra;
                                        svc_ta := TouchArea {
                                            clicked => { root.selected_row = idx; root.row_selected(idx); }
                                            VerticalLayout {
                                                HorizontalLayout {
                                                    vertical-stretch: 1;
                                                    padding-left: 8px;
                                                    padding-right: 8px;
                                                    spacing: 8px;
                                                    Text { text: row.name; width: 150px; vertical-alignment: center; overflow: elide; }
                                                    Text { text: row.status; width: 100px; vertical-alignment: center; }
                                                    Text { text: row.pid; width: 80px; vertical-alignment: center; }
                                                    Text { text: row.restarts; width: 80px; vertical-alignment: center; }
                                                    Text { text: row.exit; horizontal-stretch: 1; vertical-alignment: center; }
                                                }
                                                Rectangle { height: 1px; background: Ui.grid; }
                                            }
                                        }
                                    }
                                }
                            }
                        }
                        GroupBox {
                            vertical-stretch: 0;
                            title: root.sel_caption;
                            HorizontalLayout {
                                spacing: 6px;
                                alignment: start;
                                Button { text: "Start"; height: 28px; enabled: root.can_start; clicked => { root.start_service(); } }
                                Button { text: "Stop"; height: 28px; enabled: root.can_stop; clicked => { root.stop_service(); } }
                                Button { text: "Restart"; height: 28px; enabled: root.can_restart; clicked => { root.restart_service(); } }
                            }
                        }
                    }

                    // --- read-only config view ---
                    if root.view == "readonly": VerticalLayout {
                        spacing: 6px;
                        TextEdit {
                            vertical-stretch: 1;
                            text: root.config_text;
                            read-only: true;
                        }
                        HorizontalLayout {
                            Button { text: "Stop All & Edit Config"; clicked => { root.stop_to_edit(); } }
                            Rectangle { horizontal-stretch: 1; }
                        }
                    }

                    // --- editable config view ---
                    if root.view == "edit": VerticalLayout {
                        spacing: 6px;
                        TextEdit {
                            vertical-stretch: 1;
                            text <=> root.config_text;
                            edited => { root.config_edited(); }
                        }
                        HorizontalLayout {
                            spacing: 6px;
                            Button { text: "Start All"; clicked => { root.start_all(); } }
                            Button { text: "Validate"; clicked => { root.validate(); } }
                            Button { text: "Save"; clicked => { root.save(); } }
                            Button { text: "Reload from disk"; clicked => { root.reload_file(); } }
                            Rectangle { horizontal-stretch: 1; }
                            if root.dirty: Text {
                                text: "● unsaved changes";
                                color: #b26a00;
                                vertical-alignment: center;
                            }
                        }
                    }
                }
            }

            Tab {
                title: "Logs";
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    HorizontalLayout {
                        spacing: 8px;
                        Text { text: "Service:"; vertical-alignment: center; }
                        ComboBox {
                            min-width: 180px;
                            model: root.log_services;
                            current-index <=> root.log_current;
                            selected => { root.select_log(self.current-index); }
                        }
                        Text { text: "Lines:"; vertical-alignment: center; }
                        SpinBox {
                            minimum: 10;
                            maximum: 5000;
                            value <=> root.log_lines;
                        }
                        CheckBox {
                            text: "Follow";
                            checked <=> root.log_follow;
                            toggled => { root.follow_toggled(self.checked); }
                        }
                        Rectangle { horizontal-stretch: 1; }
                        Button { text: "Refresh"; clicked => { root.refresh_logs(); } }
                    }
                    Rectangle {
                        vertical-stretch: 1;
                        border-width: 1px;
                        border-color: Ui.border;
                        border-radius: 4px;
                        background: #ffffff;
                        clip: true;
                        log_scroll := ScrollView {
                            viewport-width: self.visible-width;
                            viewport-height: log_text_el.preferred-height;
                            log_text_el := Text {
                                text: root.log_text;
                                width: log_scroll.visible-width;
                                wrap: word-wrap;
                                font-family: "Menlo";
                                font-size: 11px;
                                color: #202020;
                            }
                        }
                    }
                }
            }

            Tab {
                title: "Routes";
                VerticalLayout {
                    padding: 8px;
                    spacing: 6px;
                    if root.editing: Text {
                        text: "Services are stopped — start them (Services tab) to view routes.";
                        color: #888888;
                    }
                    if !root.editing: Text {
                        text: "Routes grouped by service — click a URL row to open it in your browser.";
                        wrap: word-wrap;
                    }
                    if !root.editing: Rectangle {
                        vertical-stretch: 1;
                        border-width: 1px;
                        border-color: Ui.border;
                        border-radius: 4px;
                        background: #ffffff;
                        clip: true;
                        VerticalLayout {
                            // Column header.
                            Rectangle {
                                height: 26px;
                                background: Ui.header-bg;
                                HorizontalLayout {
                                    padding-left: 8px;
                                    padding-right: 8px;
                                    spacing: 8px;
                                    Text { text: "service / route"; width: 300px; font-weight: 700; vertical-alignment: center; }
                                    Text { text: "url"; width: 260px; font-weight: 700; vertical-alignment: center; }
                                    Text { text: "→ proxies to"; horizontal-stretch: 1; font-weight: 700; vertical-alignment: center; }
                                }
                            }
                            Rectangle { height: 1px; background: Ui.border; }
                            ListView {
                                vertical-stretch: 1;
                                for row[idx] in root.route_rows: Rectangle {
                                    height: 26px;
                                    background: ta.has-hover && row.url != "" ? Ui.hover
                                        : row.kind == "service-header" ? Ui.group-bg
                                        : Math.mod(idx, 2) == 0 ? #ffffff : Ui.zebra;
                                    ta := TouchArea {
                                        mouse-cursor: row.url != "" ? pointer : default;
                                        clicked => { if (row.url != "") { root.open_url(row.url); } }
                                        VerticalLayout {
                                            HorizontalLayout {
                                                vertical-stretch: 1;
                                                padding-left: row.kind == "route" ? 28px : 8px;
                                                padding-right: 8px;
                                                spacing: 8px;
                                                Text {
                                                    text: row.text;
                                                    width: row.kind == "route" ? 280px : 300px;
                                                    font-weight: row.kind == "service-header" ? 700 : 400;
                                                    color: row.muted ? #999999 : #101010;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }
                                                Text {
                                                    text: row.url;
                                                    width: 260px;
                                                    color: row.muted ? #999999 : #0055cc;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }
                                                Text {
                                                    text: row.target;
                                                    horizontal-stretch: 1;
                                                    color: #444444;
                                                    vertical-alignment: center;
                                                    overflow: elide;
                                                }
                                            }
                                            Rectangle { height: 1px; background: Ui.grid; }
                                        }
                                    }
                                }
                            }
                        }
                    }
                    if !root.editing: HorizontalLayout {
                        Button { text: "Reload"; clicked => { root.reload_routes(); } }
                        Rectangle { horizontal-stretch: 1; }
                        if root.routes_banner != "": Text {
                            text: root.routes_banner;
                            color: #b00000;
                            vertical-alignment: center;
                        }
                    }
                }
            }
        }
    }
}

export component TrayIcon inherits SystemTrayIcon {
    in property <image> tray_icon;
    icon: root.tray_icon;
    tooltip: "Local Dev Proxy";

    callback open_window();
    callback quit_app();

    Menu {
        MenuItem {
            title: "Open Manager";
            activated => { root.open_window(); }
        }
        MenuItem {
            title: "Quit";
            activated => { root.quit_app(); }
        }
    }
}
