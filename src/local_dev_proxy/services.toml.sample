# Reference configuration for local-dev-proxy.
#
# This file is not copied into the user profile and is not expected to run
# unchanged. Copy only the sections that match your services, then replace the
# example commands, ports, socket paths, and hostnames.

# The proxy listens on each address in `bind` at `http_port`.
http_port = 2800
bind = ["127.0.0.1", "::1"]

# Managed TCP service. Values in `env` are strings and are passed to the child
# process. `{API_PORT}` placeholders are expanded in command arguments.
[services.api]
command = ["my-api", "serve", "--host", "127.0.0.1", "--port", "{API_PORT}"]
env = {API_PORT = "8000", APP_ENV = "development"}

# A service can expose several routes. Hosts may be exact names or wildcards.
[[services.api.routes]]
id = "api"
hosts = ["api.localhost", "*.api.localhost"]
target_host = "127.0.0.1"
target_port_env = "API_PORT"

[[services.api.routes]]
id = "api-admin"
hosts = ["admin.api.localhost"]
target_host = "127.0.0.1"
target_port = 8001

# Unmanaged TCP service. Omitting `command` means another tool owns the process.
# `target_host` defaults to `localhost` when it is omitted.
[services.frontend]

[[services.frontend.routes]]
id = "frontend"
hosts = ["frontend.localhost"]
target_port = 5173

# Managed Unix-socket service with a socket path defined in this configuration.
[services.socket_app]
command = ["my-socket-app", "--socket", "{APP_SOCKET}"]
env = {APP_SOCKET = "run/my-socket-app.sock"}

[[services.socket_app.routes]]
id = "socket-app"
hosts = ["socket-app.localhost"]
target_socket_env = "APP_SOCKET"

# Unmanaged service at a fixed Unix-socket path.
[services.external_socket]

[[services.external_socket.routes]]
id = "external-socket"
hosts = ["external-socket.localhost"]
target_socket = "/tmp/external-http.sock"

# The manager process's OS environment is inherited by managed services and can
# also supply a route target. Export INHERITED_PORT before starting the manager.
[services.inherited_environment]
command = ["my-inherited-env-app"]

[[services.inherited_environment.routes]]
id = "inherited-environment"
hosts = ["inherited.localhost"]
target_host = "::1"
target_port_env = "INHERITED_PORT"

# Managed processes do not need proxy routes.
[services.worker]
command = ["my-worker", "run"]
env = {QUEUE = "development"}

# Keep optional configuration visible without starting its process or routes.
[services.optional_service]
command = ["my-optional-service", "--port", "9000"]
disabled = true

[[services.optional_service.routes]]
id = "optional-service"
hosts = ["optional.localhost"]
target_port = 9000
